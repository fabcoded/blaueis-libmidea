#!/bin/bash
# Blaueis Gateway — update checker and applier
#
# Usage:
#   blaueis-update              # check for updates (no changes)
#   blaueis-update --apply      # stop services → update → start → health check
#   blaueis-update --rollback   # revert to previous version
#
# Must be run with sudo (needs to stop/start systemd services and
# write to /opt/blaueis-gw which is owned by the blaueis service user).
set -e

INSTALL_DIR="/opt/blaueis-gw"
CONFIG_DIR="/etc/blaueis-gw"

RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'; BLUE='\033[0;34m'; NC='\033[0m'
ok()   { echo -e "  ${GREEN}✓${NC} $1"; }
fail() { echo -e "  ${RED}✗${NC} $1"; }
warn() { echo -e "  ${YELLOW}!${NC} $1"; }

cd "$INSTALL_DIR"

# Ensure git trusts this directory (vcs-versioning needs git describe)
git config --global --add safe.directory "$INSTALL_DIR" 2>/dev/null || true

# Determine who owns the install (run git/pip as this user)
OWNER=$(stat -c '%U' "$INSTALL_DIR")
if [ "$EUID" -eq 0 ]; then
    SUDO=""
    RUN_AS="sudo -u $OWNER"
elif command -v sudo &>/dev/null; then
    SUDO="sudo"
    RUN_AS="sudo -u $OWNER"
else
    echo "Run with sudo: sudo blaueis-update $*"
    exit 1
fi

# ── Version display helper ─────────────────────────
# Use tag if available, otherwise short commit hash
_version() {
    local ref="${1:-HEAD}"
    git describe --tags --always "$ref" 2>/dev/null || git rev-parse --short "$ref" 2>/dev/null || echo "unknown"
}

# ── Get version info ────────────────────────────────
CURRENT_SHA=$(git rev-parse HEAD 2>/dev/null || echo "")
CURRENT=$(_version HEAD)
echo -e "${BLUE}Current:${NC} $CURRENT"

$RUN_AS git fetch origin main --depth 50 -q 2>/dev/null \
    || git fetch origin main --depth 50 -q 2>/dev/null || true
REMOTE_SHA=$(git rev-parse origin/main 2>/dev/null || echo "")
LATEST=$(_version origin/main)
echo -e "${BLUE}Latest:${NC}  $LATEST"
echo ""

# ── Check mode ──────────────────────────────────────
if [ "$CURRENT_SHA" = "$REMOTE_SHA" ] && [ "$1" != "--rollback" ]; then
    echo -e "${GREEN}Up to date.${NC}"
    exit 0
fi

if [ "$1" != "--apply" ] && [ "$1" != "--rollback" ]; then
    echo -e "${YELLOW}Update available: $CURRENT → $LATEST${NC}"
    echo ""
    echo "  To apply:   sudo blaueis-update --apply"
    echo "  To rollback: sudo blaueis-update --rollback"
    exit 0
fi

# ── Rollback ────────────────────────────────────────
ROLLBACK_REF=""
if [ "$1" = "--rollback" ]; then
    # Save current HEAD so we can roll back to it
    ROLLBACK_REF="HEAD~1"
    if ! git rev-parse "$ROLLBACK_REF" &>/dev/null; then
        fail "No previous version to rollback to"
        exit 1
    fi
    echo "Rolling back: $CURRENT → $(_version $ROLLBACK_REF)"
fi

# ── Phase 1: Stop all running instances ─────────────
echo ""
echo "Stopping gateway instances..."
RUNNING_INSTANCES=()
for svc in $(systemctl list-units --type=service --no-legend 'blaueis-gateway@*' 2>/dev/null | awk '{print $1}'); do
    if systemctl is-active --quiet "$svc"; then
        $SUDO systemctl stop "$svc"
        ok "Stopped $svc"
        RUNNING_INSTANCES+=("$svc")
    fi
done
if [ ${#RUNNING_INSTANCES[@]} -eq 0 ]; then
    warn "No running instances found"
fi

# ── Phase 2: Update code (as the file owner) ───────
echo ""
echo "Updating code..."
if [ -n "$ROLLBACK_REF" ]; then
    $RUN_AS git reset --hard "$ROLLBACK_REF" -q 2>/dev/null \
        || git reset --hard "$ROLLBACK_REF" -q
else
    $RUN_AS git pull --ff-only -q 2>/dev/null \
        || git pull --ff-only -q 2>/dev/null \
        || { git fetch origin main --depth 50 -q; git reset --hard origin/main -q; }
fi
$RUN_AS "$INSTALL_DIR/venv/bin/pip" install -q -e packages/blaueis-core -e packages/blaueis-gateway
NEW_BUILD=$(_version HEAD)
ok "Code updated to $NEW_BUILD"

# ── Phase 3: Start enabled instances ────────────────
echo ""
echo "Starting enabled instances..."
STARTED=()
for cfg in "$CONFIG_DIR/instances/"*.yaml; do
    if [ ! -f "$cfg" ]; then continue; fi
    name=$(basename "$cfg" .yaml)

    # Check enabled flag
    enabled=$(python3 -c "
import yaml
with open('$cfg') as f:
    d = yaml.safe_load(f) or {}
print(d.get('enabled', True))
" 2>/dev/null || echo "True")

    if [ "$enabled" = "False" ]; then
        warn "$name — disabled, skipping"
        continue
    fi

    $SUDO systemctl start "blaueis-gateway@${name}" 2>/dev/null
    STARTED+=("$name")
done

# ── Phase 4: Health check (wait 3s, then verify) ───
if [ ${#STARTED[@]} -gt 0 ]; then
    echo ""
    echo "Health check (waiting 3s)..."
    sleep 3

    all_healthy=true
    for name in "${STARTED[@]}"; do
        svc="blaueis-gateway@${name}.service"
        if systemctl is-active --quiet "$svc"; then
            ok "$name — running"
        else
            fail "$name — FAILED"
            echo "      Check: journalctl -u $svc --no-pager -n 20"
            echo "      Rollback: sudo blaueis-update --rollback"
            all_healthy=false
        fi
    done

    echo ""
    if [ "$all_healthy" = true ]; then
        echo -e "${GREEN}Update complete: $NEW_BUILD${NC}"
    else
        echo -e "${RED}Some instances failed to start.${NC}"
        echo "  Review the logs, then either fix the issue or rollback:"
        echo "  sudo blaueis-update --rollback"
        exit 1
    fi
else
    echo ""
    echo -e "${GREEN}Update complete: $NEW_BUILD (no instances to start)${NC}"
fi
