#!/bin/bash
# Blaueis Gateway — unified CLI
#
# Usage:
#   blaueis-gw <command> [options]
#
# Installed as /usr/local/bin/blaueis-gw by the installer.
set -e

# Resolve real path (works through symlinks)
SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"
PACKAGE_DIR="$(dirname "$SCRIPT_DIR")"
INSTALL_DIR="$(dirname "$(dirname "$PACKAGE_DIR")")"
CONFIG_DIR="/etc/blaueis-gw"

BLUE='\033[0;34m'; YELLOW='\033[1;33m'; NC='\033[0m'

_version() {
    git -C "$INSTALL_DIR" describe --tags --always 2>/dev/null \
        || echo "unknown"
}

_instances() {
    # List configured instance names (stem of each .yaml in instances/)
    local dir="$CONFIG_DIR/instances"
    if [ -d "$dir" ]; then
        for f in "$dir"/*.yaml; do
            [ -f "$f" ] && basename "$f" .yaml
        done
    fi
}

cmd_help() {
    echo "Usage: blaueis-gw <command> [options]"
    echo ""
    echo "Commands:"
    echo "  configure    Add or edit a gateway instance"
    echo "  update       Check for / apply updates"
    echo "  uninstall    Remove the gateway installation"
    echo "  run          Run gateway in foreground (Ctrl+C to stop)"
    echo "  status       Show status of all gateway instances"
    echo "  logs         Show gateway logs (-f to follow, -n COUNT for lines)"
    echo "  instances    List configured instances"
    echo "  help         Show this help message"
    echo ""
    echo "Options:"
    echo "  --version    Show version"
    echo ""
    echo "Examples:"
    echo "  blaueis-gw status"
    echo "  blaueis-gw logs atelier        # last 50 lines"
    echo "  blaueis-gw logs atelier -f     # follow (continuous)"
    echo "  blaueis-gw logs atelier -n 200 # last 200 lines"
    echo "  blaueis-gw logs -f             # follow all instances"
    echo "  blaueis-gw configure --instance atelier"
    echo "  sudo blaueis-gw update --apply"
    echo "  sudo blaueis-gw uninstall --purge"
}

cmd_configure() {
    exec "$INSTALL_DIR/venv/bin/blaueis-configure" "$@"
}

cmd_update() {
    exec "$SCRIPT_DIR/blaueis-update" "$@"
}

cmd_uninstall() {
    exec "$SCRIPT_DIR/blaueis-uninstall" "$@"
}

cmd_run() {
    if [ ! -d "$CONFIG_DIR/instances" ] || \
       [ -z "$(ls "$CONFIG_DIR/instances/"*.yaml 2>/dev/null)" ]; then
        echo "No instance configured. Run: blaueis-gw configure"
        exit 1
    fi
    exec "$INSTALL_DIR/venv/bin/python" -m blaueis.gateway.server "$@"
}

cmd_status() {
    echo -e "${BLUE}Blaueis Gateway Status${NC}  ($(_version))"
    echo ""
    found=false
    for svc in $(systemctl list-units --type=service --no-legend \
                 'blaueis-gateway@*' 2>/dev/null | awk '{print $1}'); do
        found=true
        systemctl status --no-pager "$svc" 2>/dev/null || true
        echo ""
    done
    if [ "$found" = false ]; then
        echo "No gateway instances found."
    fi
}

cmd_instances() {
    local names
    names=$(_instances)
    if [ -z "$names" ]; then
        echo "No instances configured. Run: blaueis-gw configure"
        return
    fi
    echo "Configured instances:"
    for name in $names; do
        local svc="blaueis-gateway@${name}.service"
        local state
        state=$(systemctl is-active "$svc" 2>/dev/null || true)
        case "$state" in
            active)   echo -e "  ${BLUE}●${NC} $name (running)" ;;
            failed)   echo -e "  ${YELLOW}●${NC} $name (failed)" ;;
            *)        echo "  ○ $name (stopped)" ;;
        esac
    done
}

cmd_logs() {
    local unit='blaueis-gateway@*'
    if [ -n "$1" ] && [[ "$1" != -* ]]; then
        unit="blaueis-gateway@${1}.service"
        shift
    fi
    # Default to last 50 lines; pass -f for follow or -n N for count
    local has_n=false has_f=false
    for arg in "$@"; do
        case "$arg" in -n) has_n=true ;; -f|--follow) has_f=true ;; esac
    done
    if [ "$has_f" = true ]; then
        journalctl -u "$unit" -f "$@"
    elif [ "$has_n" = true ]; then
        journalctl -u "$unit" --no-pager "$@"
    else
        journalctl -u "$unit" --no-pager -n 50 "$@"
    fi
}

# ── Dispatch ──────────────────────────────────────
case "${1:-help}" in
    configure)  shift; cmd_configure "$@" ;;
    update)     shift; cmd_update "$@" ;;
    uninstall)  shift; cmd_uninstall "$@" ;;
    run)        shift; cmd_run "$@" ;;
    status)     shift; cmd_status "$@" ;;
    logs)       shift; cmd_logs "$@" ;;
    instances)  shift; cmd_instances "$@" ;;
    help|--help|-h) cmd_help ;;
    --version|-V)   echo "blaueis-gw $(_version)" ;;
    *)
        echo "Unknown command: $1"
        echo ""
        cmd_help
        exit 1
        ;;
esac
